{
  "name": "bwell",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "restart": "expo start -c",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "type-check": "tsc --noEmit --incremental",
    "lint:eslint": "eslint \"**/*.*{ts,tsx,js,jsx}\"",
    "lint:prettier": "prettier --check .",
    "lint": "expo lint && npm run lint:eslint  && npm run lint:prettier && npm run type-check",
    "prepare": "husky",
    "clean": "rm -rf node_modules .expo .expo-shared ios && npm ci && npx expo install --fix && cd ios && pod install",
    "start-clean": "expo start -c",
    "verify": "npx expo-doctor",
    "fix": "npx expo install --check",
    "upgrade": "npx expo install expo@latest && npx expo install --fix && npx expo-doctor",
    "publish": "eas update --branch main --environment production --message \"Update $(date)\"",
    "publish-web": "npx expo export --platform web && eas deploy --environment production",
    "update-types": "npm uninstall @milobedini/shared-types && npm i @milobedini/shared-types -D",
    "build:ios-sim": "EXPO_PUBLIC_E2E=true npx expo run:ios",
    "test:e2e": "maestro test @.maestro/.env .maestro/flows/**",
    "test:e2e:studio": "maestro studio",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "test:e2e:full": "bash scripts/run-e2e.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-vector-icons/ant-design": "^12.3.0",
    "@react-native-vector-icons/ionicons": "^12.3.0",
    "@react-native-vector-icons/material-design-icons": "^12.3.0",
    "@react-native-vector-icons/material-icons": "^12.3.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/material-top-tabs": "^7.3.6",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-query": "^5.82.0",
    "axios": "^1.10.0",
    "clsx": "^2.1.1",
    "expo": "^55.0.11",
    "expo-blur": "~55.0.13",
    "expo-constants": "~55.0.12",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.13",
    "expo-image": "~55.0.8",
    "expo-intent-launcher": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.12",
    "expo-mail-composer": "~55.0.12",
    "expo-router": "~55.0.11",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.14",
    "expo-updates": "~55.0.19",
    "expo-video": "~55.0.14",
    "expo-web-browser": "~55.0.13",
    "formik": "^2.4.6",
    "lottie-react-native": "~7.3.1",
    "moti": "^0.30.0",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-confirmation-code-field": "^8.0.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pager-view": "8.0.0",
    "react-native-paper": "^5.14.5",
    "react-native-paper-dates": "^0.22.49",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "sonner-native": "^0.23.1",
    "yup": "^1.6.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@milobedini/shared-types": "^1.0.92",
    "@tanstack/eslint-plugin-query": "^5.81.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.14",
    "lint-staged": "^16.4.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.39.1"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "hooks/**/*.{ts,tsx}",
      "stores/**/*.{ts,tsx}",
      "utils/**/*.{ts,tsx}",
      "api/**/*.{ts,tsx}",
      "!**/*.test.{ts,tsx}",
      "!**/*.d.ts",
      "!**/index.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@milobedini/shared-types)"
    ]
  }
}
